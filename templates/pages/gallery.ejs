<%- include('../partials/head', { title: 'Gallery | DTPLab', description: 'DTPLab 갤러리', pageKey: 'gallery', scripts: ['gallery.js'] }) %>
<%- include('../partials/header') %>
<main id="main">
  <section class="page-hero"><div class="shell"><h1>Gallery</h1></div></section>
  <section class="content-section"><div class="shell"><div class="gallery-events" id="gallery-content"></div></div></section>
</main>
<dialog class="lightbox" id="gallery-lightbox" aria-label="이미지 크게 보기">
  <div class="lightbox-inner">
    <button class="lightbox-close" type="button" aria-label="닫기">×</button>
    <button class="lightbox-nav lightbox-prev" type="button" aria-label="이전 이미지">‹</button>
    <img id="lightbox-image" alt="">
    <p class="lightbox-caption" id="lightbox-caption"></p>
    <button class="lightbox-nav lightbox-next" type="button" aria-label="다음 이미지">›</button>
  </div>
</dialog>
<%- include('../partials/footer') %>
